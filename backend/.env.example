# OutreachRoute Pro — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=replace-me-with-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/outreachroutepro

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-me-with-another-long-random-string

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=replace-me

# ── Email (choose one provider) ───────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid

# SendGrid
SENDGRID_API_KEY=replace-me
FROM_EMAIL=noreply@yourdomain.com

# Amazon SES (alternative)
# EMAIL_PROVIDER=ses
# AWS_SES_REGION=us-east-1

# ── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
S3_BUCKET_NAME=outreachroutepro-uploads
