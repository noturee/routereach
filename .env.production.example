# ── RouteReach Production Environment Variables ────────────────────────────
# Copy this file to .env.production and fill in all values.
# In AWS, store these in Secrets Manager under the key "routereach/production"
# and reference them from the ECS task definition — never bake secrets into images.

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_ENV=production

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_ME
JWT_SECRET_KEY=REPLACE_ME

# ── Database ───────────────────────────────────────────────────────────────
# RDS endpoint from the AWS Console (Databases → <instance> → Endpoint)
DATABASE_URL=postgresql://<db-user>:<db-password>@<rds-endpoint>:5432/routereach

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://routereachpro.com

# ── Email ──────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid        # sendgrid | ses
SENDGRID_API_KEY=REPLACE_ME
FROM_EMAIL=no-reply@routereachpro.com

# ── SMS (Twilio) ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_PHONE_NUMBER=REPLACE_ME   # E.164 format, e.g. +12025551234

# ── Google Maps ────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=REPLACE_ME

# ── AWS (only needed for local testing; ECS uses the task IAM role) ────────
AWS_REGION=us-east-1
# Do NOT set these in ECS — use the task role instead
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Bucket used for applicant document uploads and report exports
AWS_S3_BUCKET=routereach-uploads-prod

# ── Frontend (set before running: npm run build) ───────────────────────────
VITE_API_BASE_URL=https://api.routereachpro.com
